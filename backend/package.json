{
  "name": "project-tracker-backend",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node server.cjs",
    "server": "node server.cjs",
    "kill-port": "for /f \"tokens=5\" %a in ('netstat -ano ^| findstr :3001 ^| findstr LISTENING') do taskkill /PID %a /F",
    "fresh": "npm run kill-port & npm run server"
  },
  "dependencies": {
    "@github/copilot-sdk": "^1.0.0-beta.4",
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.2.0",
    "mssql": "^12.5.3",
    "openai": "^6.38.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
